    { "id": "SC_HALAL",          "label_vi": "Halal",                  "label_en": "Halal",          "note": "Theo quy định Hồi giáo" },
    { "id": "SC_KOSHER",         "label_vi": "Kosher",                 "label_en": "Kosher",         "note": "Theo quy định Do Thái" },
    { "id": "SC_ATHLETE",        "label_vi": "Vận động viên",          "label_en": "Athlete",        "note": "Nhu cầu protein & năng lượng cao hơn" }
