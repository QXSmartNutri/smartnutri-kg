    { "id": "AL_LOW",         "label_vi": "Vận động nhẹ",         "label_en": "Low Active",          "pal": 1.6, "note": "PAL 1.6 — đi bộ ~2–3km/ngày" },
    { "id": "AL_MODERATE",    "label_vi": "Vận động vừa",         "label_en": "Moderately Active",   "pal": 1.8, "note": "PAL 1.8 — tập thể dục 3–5 ngày/tuần" },
    { "id": "AL_HIGH",        "label_vi": "Vận động nhiều",       "label_en": "Active",              "pal": 2.0, "note": "PAL 2.0 — tập thể dục hàng ngày, cường độ cao" },
    { "id": "AL_VERY_HIGH",   "label_vi": "Vận động rất nhiều",   "label_en": "Very Active",         "pal": 2.2, "note": "PAL 2.2 — vận động viên, lao động thể lực nặng" }
