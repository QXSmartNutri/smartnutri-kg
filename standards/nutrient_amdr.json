{
  "$schema": "https://smartnutri.org/schemas/standards",
  "version": "1.1.0",
  "description": "Acceptable Macronutrient Distribution Ranges (AMDR) theo IOM — tỉ lệ % tổng năng lượng cho từng nhóm macronutrient.",
  "source": "Institute of Medicine. Dietary Reference Intakes for Energy, Carbohydrate, Fiber, Fat, Fatty Acids, Cholesterol, Protein, and Amino Acids. 2005.",
  "unit": "% tổng năng lượng (%E)",
  "note": "AMDR là khoảng tỉ lệ năng lượng được khuyến nghị — không phải lượng tuyệt đối (g/day). Dùng kết hợp với nutrient-rda.json để tính khẩu phần cụ thể.",
  "amdr": {
    "NUT_carbohydrate_total": {
      "min_pct": 45, "max_pct": 65, "unit": "%E",
      "note": "Bao gồm tinh bột, đường, chất xơ",
      "by_age": {
        "AG_CHILD_1_3Y":    { "min_pct": 45, "max_pct": 65 },
        "AG_CHILD_4_8Y":    { "min_pct": 45, "max_pct": 65 },
        "AG_CHILD_9_13Y":   { "min_pct": 45, "max_pct": 65 },
        "AG_TEEN_14_18Y_M": { "min_pct": 45, "max_pct": 65 },
        "AG_TEEN_14_18Y_F": { "min_pct": 45, "max_pct": 65 },
        "AG_ADULT_19_30Y_M":{ "min_pct": 45, "max_pct": 65 },
        "AG_ADULT_19_30Y_F":{ "min_pct": 45, "max_pct": 65 },
        "AG_ADULT_31_50Y_M":{ "min_pct": 45, "max_pct": 65 },
        "AG_ADULT_31_50Y_F":{ "min_pct": 45, "max_pct": 65 },
        "AG_ADULT_51_70Y_M":{ "min_pct": 45, "max_pct": 65 },
        "AG_ADULT_51_70Y_F":{ "min_pct": 45, "max_pct": 65 },
        "AG_ELDER_70Y_M":   { "min_pct": 45, "max_pct": 65 },
        "AG_ELDER_70Y_F":   { "min_pct": 45, "max_pct": 65 },
        "AG_PREGNANT":      { "min_pct": 45, "max_pct": 65 },
        "AG_LACTATING":     { "min_pct": 45, "max_pct": 65 }
      }
    },
    "NUT_protein": {
      "min_pct": 10, "max_pct": 35, "unit": "%E",
      "note": "Trẻ 1–3 tuổi có AMDR rộng hơn do nhu cầu tăng trưởng",
      "by_age": {
        "AG_CHILD_1_3Y":    { "min_pct": 5,  "max_pct": 20 },
        "AG_CHILD_4_8Y":    { "min_pct": 10, "max_pct": 30 },
        "AG_CHILD_9_13Y":   { "min_pct": 10, "max_pct": 30 },
        "AG_TEEN_14_18Y_M": { "min_pct": 10, "max_pct": 35 },
        "AG_TEEN_14_18Y_F": { "min_pct": 10, "max_pct": 35 },
        "AG_ADULT_19_30Y_M":{ "min_pct": 10, "max_pct": 35 },
        "AG_ADULT_19_30Y_F":{ "min_pct": 10, "max_pct": 35 },
        "AG_ADULT_31_50Y_M":{ "min_pct": 10, "max_pct": 35 },
        "AG_ADULT_31_50Y_F":{ "min_pct": 10, "max_pct": 35 },
        "AG_ADULT_51_70Y_M":{ "min_pct": 10, "max_pct": 35 },
        "AG_ADULT_51_70Y_F":{ "min_pct": 10, "max_pct": 35 },
        "AG_ELDER_70Y_M":   { "min_pct": 10, "max_pct": 35 },
        "AG_ELDER_70Y_F":   { "min_pct": 10, "max_pct": 35 },
        "AG_PREGNANT":      { "min_pct": 10, "max_pct": 35 },
        "AG_LACTATING":     { "min_pct": 10, "max_pct": 35 }
      }
    },
    "NUT_fat_total": {
      "min_pct": 20, "max_pct": 35, "unit": "%E",
      "note": "Trẻ nhỏ cần tỉ lệ chất béo cao hơn cho phát triển não bộ",
      "by_age": {
        "AG_CHILD_1_3Y":    { "min_pct": 30, "max_pct": 40 },
        "AG_CHILD_4_8Y":    { "min_pct": 25, "max_pct": 35 },
        "AG_CHILD_9_13Y":   { "min_pct": 25, "max_pct": 35 },
        "AG_TEEN_14_18Y_M": { "min_pct": 25, "max_pct": 35 },
        "AG_TEEN_14_18Y_F": { "min_pct": 25, "max_pct": 35 },
        "AG_ADULT_19_30Y_M":{ "min_pct": 20, "max_pct": 35 },
        "AG_ADULT_19_30Y_F":{ "min_pct": 20, "max_pct": 35 },
        "AG_ADULT_31_50Y_M":{ "min_pct": 20, "max_pct": 35 },
        "AG_ADULT_31_50Y_F":{ "min_pct": 20, "max_pct": 35 },
        "AG_ADULT_51_70Y_M":{ "min_pct": 20, "max_pct": 35 },
        "AG_ADULT_51_70Y_F":{ "min_pct": 20, "max_pct": 35 },
        "AG_ELDER_70Y_M":   { "min_pct": 20, "max_pct": 35 },
        "AG_ELDER_70Y_F":   { "min_pct": 20, "max_pct": 35 },
        "AG_PREGNANT":      { "min_pct": 20, "max_pct": 35 },
        "AG_LACTATING":     { "min_pct": 20, "max_pct": 35 }
      }
    },
    "NUT_sugar_total": {
      "max_pct": 10, "unit": "%E",
      "source": "WHO 2015 Guideline on Sugars Intake",
      "note": "Added sugars — WHO khuyến nghị <10%E, lý tưởng <5%E. Không phải AMDR chính thức của IOM."
    },
    "fatty_acid_subtypes": {
      "note": "Phân nhóm chất béo — tham khảo thêm",
      "saturated_fat":     { "max_pct": 10, "unit": "%E", "source": "AHA/WHO" },
      "trans_fat":         { "max_pct": 1,  "unit": "%E", "source": "WHO 2023" },
      "omega6_linoleic":   { "min_pct": 5,  "max_pct": 10, "unit": "%E", "source": "IOM" },
      "omega3_ala":        { "min_pct": 0.6,"max_pct": 1.2,"unit": "%E", "source": "IOM" }
    }
  }
}
