  "label_requirements": {
    "mandatory": ["vi", "en"],
    "note": "Mọi entity phải có rdfs:label bằng vi & en. Ngôn ngữ khác bổ sung khi có dữ liệu.",
    "format_jsonld": [
      { "@value": "Tên tiếng Việt", "@language": "vi" },
      { "@value": "English name",   "@language": "en" }
    ],
    "format_turtle": "rdfs:label \"Tên tiếng Việt\"@vi , \"English name\"@en ."
  },
  "naming_conventions": {
    "scientific_name": {
      "field": "sn:scientificName",
      "note": "Tên khoa học dùng tiếng Latin — không cần @language tag"
    },
    "common_name": {
      "field": "rdfs:label",
      "note": "Tên thông thường — bắt buộc vi & en"
    },
    "synonym": {
      "field": "skos:altLabel",
      "note": "Tên đồng nghĩa, tên địa phương — dùng cùng format @language"
    }
  }
