        "NUT_leucine":       { "type": "RDA", "has_ul": false, "has_dv": false, "unit": "mg/kg/day" },
        "NUT_lysine":        { "type": "RDA", "has_ul": false, "has_dv": false, "unit": "mg/kg/day" },
        "NUT_methionine":    { "type": "RDA", "has_ul": false, "has_dv": false, "unit": "mg/kg/day", "note": "+ Cysteine" },
