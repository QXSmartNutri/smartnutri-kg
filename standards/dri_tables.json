        "NUT_tryptophan":    { "type": "RDA", "has_ul": false, "has_dv": false, "unit": "mg/kg/day" },
        "NUT_valine":        { "type": "RDA", "has_ul": false, "has_dv": false, "unit": "mg/kg/day" }
