{
  "$schema": "https://smartnutri.org/schemas/standards",
  "version": "1.1.0",
  "description": "DRI Tables — Bảng tổng hợp tham chiếu nhanh toàn bộ Dietary Reference Intakes. Chi tiết xem nutrient-rda.json, nutrient-ul.json, nutrient-dv.json.",
  "source": "Institute of Medicine. Dietary Reference Intakes. National Academies Press.",
  "files": {
    "rda_ai":  "standards/nutrient-rda.json",
    "ul":      "standards/nutrient-ul.json",
    "dv":      "standards/nutrient-dv.json",
    "amdr":    "standards/nutrient_amdr.json",
    "units":   "standards/nutrient-units.json",
    "age_groups": "standards/age-groups.json"
  },
