{
  "$schema": "https://smartnutri.org/schemas/advanced-meal-distribution-v2",
  "version": "2.0.0",
  "description": "Dynamic Nutrient Allocation & Timing Architecture (Chrononutrition Engine)",
  "last_updated": "2026-07-01",

  "----------------------------------------------------------------": "1. MEAL PATTERNS WITH MACRO SPLITS (Phân bổ năng lượng & vĩ chất chi tiết)",
  "meal_patterns": {
    "PATTERN_3_MEALS": {
      "label_vi": "3 bữa chính tiêu chuẩn",
      "slots": {
        "breakfast": { "pct_energy": 25, "macro_bias": { "carbs": 0.25, "protein": 0.25, "fat": 0.20 }, "optimal_time_window": "06:30-08:30" },
        "lunch":     { "pct_energy": 40, "macro_bias": { "carbs": 0.40, "protein": 0.40, "fat": 0.40 }, "optimal_time_window": "11:30-13:00" },
        "dinner":    { "pct_energy": 35, "macro_bias": { "carbs": 0.35, "protein": 0.35, "fat": 0.40 }, "optimal_time_window": "18:00-20:00" }
      }
    },
    "PATTERN_5_6_SMALL": {
      "label_vi": "5-6 bữa nhỏ phân mảnh (Tiểu đường / Gym / Dạ dày)",
      "slots": {
        "breakfast":       { "pct_energy": 18, "macro_bias": { "carbs": 0.15, "protein": 0.20, "fat": 0.15 }, "optimal_time_window": "06:30-07:30" },
        "morning_snack":   { "pct_energy": 12, "macro_bias": { "carbs": 0.12, "protein": 0.10, "fat": 0.10 }, "optimal_time_window": "09:30-10:15" },
        "lunch":           { "pct_energy": 25, "macro_bias": { "carbs": 0.25, "protein": 0.25, "fat": 0.25 }, "optimal_time_window": "12:00-13:00" },
        "afternoon_snack": { "pct_energy": 12, "macro_bias": { "carbs": 0.13, "protein": 0.15, "fat": 0.10 }, "optimal_time_window": "15:30-16:30" },
        "dinner":          { "pct_energy": 23, "macro_bias": { "carbs": 0.25, "protein": 0.20, "fat": 0.30 }, "optimal_time_window": "18:30-19:30" },
        "evening_snack":   { "pct_energy": 10, "macro_bias": { "carbs": 0.10, "protein": 0.10, "fat": 0.10 }, "optimal_time_window": "21:00-21:30" }
      }
    }
  },

  "----------------------------------------------------------------": "2. CHRONONUTRITION & MICRONUTRIENT TIMING RULES (Hàm phân bổ vi chất động)",
  "micronutrient_timing_rules": {
    "NUT_iron": {
      "preferred_slots": ["breakfast", "lunch"],
      "synergistic_co_ingestion": ["NUT_vitamin_c"],
      "antagonist_co_ingestion": ["NUT_calcium", "CMP_polyphenol_tea_coffee"],
      "allocation_constraint": { "min_pct_of_rda_in_preferred_slot": 60 }
    },
    "NUT_calcium": {
      "preferred_slots": ["dinner", "evening_snack"],
      "note": "Hấp thu tốt hơn vào ban đêm do nhịp sinh học xương và giảm nồng độ canxi máu thụ động",
      "antagonist_co_ingestion": ["NUT_iron", "NUT_zinc"],
      "allocation_constraint": { "min_pct_of_rda_in_preferred_slot": 50 }
    },
    "NUT_protein": {
      "strategy": "EVEN_DISTRIBUTION",
      "note": "Kích hoạt tối đa Muscle Protein Synthesis (Ngưỡng Leucine Trigger ~3g/bữa)",
      "allocation_constraint": { "max_delta_between_main_meals": 0.10 }
    },
    "NUT_vitamin_b_complex": {
      "preferred_slots": ["breakfast"],
      "allocation_constraint": { "min_pct_of_rda_in_preferred_slot": 40 }
    }
  },

  "----------------------------------------------------------------": "3. POPULATION & PATHOLOGICAL OVERRIDES (Cấu hình ghi đè theo đối tượng)",
  "population_pattern_overrides": {
    "COND_diabetic": {
      "enforced_pattern": "PATTERN_5_6_SMALL",
      "rules": {
        "strict_carb_cap_per_snack_g": 15,
        "even_carb_distribution": true,
        "suppress_evening_snack_carbs": true
      }
    },
    "COND_geriatric_70y": {
      "enforced_pattern": "PATTERN_5_6_SMALL",
      "rules": {
        "max_volume_per_meal_ml": 400,
        "protein_density_boost_factor": 1.25
      }
    },
    "COND_gerd": {
      "enforced_pattern": "PATTERN_3_MEALS",
      "rules": {
        "no_eating_before_sleep_hours": 3,
        "dinner_max_fat_pct": 20
      }
    }
  },

  "----------------------------------------------------------------": "4. INTERMITTENT FASTING INTEGRATION (Tích hợp Nhịn ăn gián đoạn thực tế)",
  "intermittent_fasting_engine": {
    "IF_16_8": {
      "eating_window_duration_hours": 8,
      "allowed_slots_mapping": {
        "default_schedule": { "start_time": "12:00", "end_time": "20:00" },
        "active_meals": ["lunch", "afternoon_snack", "dinner"],
        "redistribution_logic": {
          "strategy": "COMPRESS_AND_SCALE",
          "target_pattern": "PATTERN_3_MEALS",
          "scale_multipliers": {
            "lunch": 0.45,
            "afternoon_snack": 0.15,
            "dinner": 0.40
          }
        }
      }
    }
  }
}
