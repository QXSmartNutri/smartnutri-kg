{
  "metadata": {
    "schema_id": "https://smartnutri.org/schemas/scoring-meta-layer-v2.6",
    "version": "2.6.0",
    "module_name": "Dynamic_Scoring_and_Normalization_Engine",
    "domain": "Precision_Clinical_Nutrition",
    "organization": "SmartNutri R&D Center",
    "environment_target": "production",
    "compiled_at": "2026-07-01T00:00:00Z"
  },

  "----------------------------------------------------------------": "1. NORMALIZATION RULES (Quy tắc chuẩn hóa đồng nhất trục tọa độ toán học)",
  "normalization_rules": {
    "global_normalization_bounds": [0, 100],
    "methods": {
      "MIN_MAX_SCALING": {
        "formula": "((x - x_min) / (x_max - x_min)) * 100",
        "applied_to": ["COMP_macro_ratio", "COMP_behavioral_match"]
      },
      "Z_SCORE_NORMALIZATION": {
        "formula": "(x - population_mean) / population_std_dev",
        "applied_to": ["biomarker_trends_alignment"]
      }
    },
    "re_normalization_strategy": "SUM_TO_ONE_WEIGHT_FORCE",
    "note": "Đảm bảo sau khi áp các hàm phi tuyến (Sigmoid, Log), dữ liệu thô của mọi cấu phần phải được ép về thang [0, 100] trước khi nhân trọng số."
  },

  "----------------------------------------------------------------": "2. UNCERTAINTY PENALTY MECHANISMS (Hàm phạt sai số và độ mờ dữ liệu)",
  "uncertainty_penalty": {
    "mode": "PROBABILISTIC_CONFIDENCE_DECAY",
    "base_penalty_formula": "score_adjusted = raw_score * pow(data_confidence_score, decay_exponent)",
    "decay_exponent": 1.5,
    "thresholds": {
      "confidence_1_0_to_0_9": { "penalty_modifier": 1.0, "action": "none" },
      "confidence_0_89_to_0_7": { "penalty_modifier": 0.85, "action": "apply_soft_penalty" },
      "confidence_below_0_7": { "penalty_modifier": 0.5, "action": "trigger_fallback_warning_flag" }
    },
    "note": "Nếu món ăn sử dụng dữ liệu thành phần thực phẩm nội suy (Imputed data) có độ tin cậy thấp, điểm số sẽ tự động bị đánh tụt để thuật toán Solver ưu tiên chọn các thực phẩm có dữ liệu Lab-test chuẩn xác."
  },

  "----------------------------------------------------------------": "3. POPULATION-SPECIFIC MATHEMATICAL MODELS (Cấu hình hằng số theo quần thể)",
  "population_specific_models": {
    "POP_vietnamese_urban": {
      "COMP_glycemic_variability": { "inflection_point_gl": 14.2, "steepness_factor": 0.35 },
      "COMP_biocompatibility": { "sub_components": { "sodium_penalty": { "hard_ceiling_pct_dv_per_meal": 40 } } },
      "taxonomy_bias_ref": "cultural_anchors.CULT_vietnamese"
    },
    "POP_euro_caucasian": {
      "COMP_glycemic_variability": { "inflection_point_gl": 16.5, "steepness_factor": 0.28 },
      "COMP_biocompatibility": { "sub_components": { "sodium_penalty": { "hard_ceiling_pct_dv_per_meal": 50 } } },
      "taxonomy_bias_ref": "cultural_anchors.CULT_western"
    }
  },

