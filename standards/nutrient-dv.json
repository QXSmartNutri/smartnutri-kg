{
  "$schema": "https://smartnutri.org/schemas/standards",
  "version": "1.1.0",
  "description": "Daily Values (DV) theo FDA 2020 — dùng cho nhãn dinh dưỡng (Nutrition Facts Label). Cơ sở tính %DV trên bao bì thực phẩm.",
  "source": "U.S. FDA. Food Labeling: Revision of the Nutrition and Supplement Facts Labels. 2020.",
  "reference_population": "Người lớn và trẻ em ≥4 tuổi",
  "reference_calorie": 2000,
  "note": "%DV = (lượng nutrient trong khẩu phần / DV) × 100",
  "nutrients": {
    "energy": {
      "NUT_energy": { "dv": 2000, "unit": "kcal" }
    },
    "macronutrients": {
      "NUT_fat_total":          { "dv": 78,   "unit": "g",  "note": "≤78g/day" },
      "NUT_carbohydrate_total": { "dv": 275,  "unit": "g"  },
      "NUT_fiber":              { "dv": 28,   "unit": "g"  },
      "NUT_sugar_total":        { "dv": 50,   "unit": "g",  "note": "Added sugars — <10% tổng năng lượng" },
      "NUT_protein":            { "dv": 50,   "unit": "g"  }
    },
    "vitamins": {
      "NUT_vitamin_a":   { "dv": 900,   "unit": "μg RAE", "note": "Tương đương 3000 IU" },
      "NUT_vitamin_d":   { "dv": 20,    "unit": "μg",     "note": "Tương đương 800 IU" },
      "NUT_vitamin_e":   { "dv": 15,    "unit": "mg",     "note": "Tương đương 22.4 IU" },
      "NUT_vitamin_k":   { "dv": 120,   "unit": "μg"     },
      "NUT_vitamin_c":   { "dv": 90,    "unit": "mg"     },
      "NUT_vitamin_b1":  { "dv": 1.2,   "unit": "mg"     },
      "NUT_vitamin_b2":  { "dv": 1.3,   "unit": "mg"     },
      "NUT_vitamin_b3":  { "dv": 16,    "unit": "mg NE"  },
      "NUT_vitamin_b5":  { "dv": 5,     "unit": "mg"     },
      "NUT_vitamin_b6":  { "dv": 1.7,   "unit": "mg"     },
      "NUT_vitamin_b7":  { "dv": 30,    "unit": "μg"     },
      "NUT_vitamin_b9":  { "dv": 400,   "unit": "μg DFE" },
      "NUT_vitamin_b12": { "dv": 2.4,   "unit": "μg"     }
    },
    "minerals": {
      "NUT_calcium":    { "dv": 1300,  "unit": "mg"  },
      "NUT_iron":       { "dv": 18,    "unit": "mg"  },
      "NUT_magnesium":  { "dv": 420,   "unit": "mg"  },
      "NUT_phosphorus": { "dv": 1250,  "unit": "mg"  },
      "NUT_potassium":  { "dv": 4700,  "unit": "mg"  },
      "NUT_sodium":     { "dv": 2300,  "unit": "mg"  },
      "NUT_zinc":       { "dv": 11,    "unit": "mg"  },
      "NUT_copper":     { "dv": 0.9,   "unit": "mg"  },
      "NUT_manganese":  { "dv": 2.3,   "unit": "mg"  },
      "NUT_selenium":   { "dv": 55,    "unit": "μg"  },
      "NUT_iodine":     { "dv": 150,   "unit": "μg"  },
      "NUT_chromium":   { "dv": 35,    "unit": "μg"  },
      "NUT_molybdenum": { "dv": 45,    "unit": "μg"  },
      "NUT_chloride":   { "dv": 2300,  "unit": "mg"  },
      "NUT_fluoride":   { "dv": 4,     "unit": "mg"  },
      "NUT_sulfur":     { "dv": null,  "unit": "mg",  "note": "Không có DV chính thức" }
    },
    "amino_acids_eaa": {
      "note": "FDA không thiết lập DV riêng cho từng EAA — dùng tổng Protein DV = 50g",
      "NUT_histidine":     { "dv": null },
      "NUT_isoleucine":    { "dv": null },
      "NUT_leucine":       { "dv": null },
      "NUT_lysine":        { "dv": null },
      "NUT_methionine":    { "dv": null },
      "NUT_phenylalanine": { "dv": null },
      "NUT_threonine":     { "dv": null },
      "NUT_tryptophan":    { "dv": null },
      "NUT_valine":        { "dv": null }
    }
  },
  "dv_thresholds": {
    "low":  { "threshold": 5,  "label": "Thấp (Low)",   "note": "≤5% DV — nguồn nghèo nutrient này" },
    "high": { "threshold": 20, "label": "Cao (High)",   "note": "≥20% DV — nguồn giàu nutrient này" }
  }
}
