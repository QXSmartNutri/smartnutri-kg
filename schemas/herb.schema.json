{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartnutri.org/schemas/herb.schema.json",
  "title": "Herb",
  "description": "JSON Schema cho entity Herb (Dược liệu). ID prefix: HERB_. Phase 1.",
  "type": "object",
  "required": ["@context", "@id", "@type", "sn:entityId", "rdfs:label"],
  "properties": {
    "@context": { "type": ["string", "object"] },
    "@id": {
      "type": "string",
      "pattern": "^https://smartnutri\\.org/entity/HERB_[0-9]{8}_[0-9]{6}(_[0-9]{6})?$"
    },
    "@type": { "type": "string", "const": "sn:Herb" },
    "sn:entityId": {
      "type": "string",
      "pattern": "^HERB_[0-9]{8}_[0-9]{6}(_[0-9]{6})?$"
    },
    "rdfs:label": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["@value", "@language"],
        "properties": {
          "@value": { "type": "string" },
          "@language": { "type": "string", "pattern": "^[a-z]{2}(-[A-Za-z]+)?$" }
        }
      },
      "minItems": 2
    },
    "rdfs:comment": { "type": "string" },
    "sn:scientificName": { "type": "string" },
    "sn:family": { "type": "string", "description": "Họ thực vật (Botanical family)" },
    "sn:partUsed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Bộ phận sử dụng: root, leaf, flower, seed, bark, whole_plant"
    },
    "sn:traditionalSystem": {
      "type": "array",
      "items": { "type": "string", "enum": ["yhct_viet_nam", "tcm_china", "ayurveda_india", "kampo_japan"] }
    },
    "sn:functionalGroup": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sn:contains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["@id"],
        "properties": {
          "@id": { "type": "string" },
          "sn:amountPer100g": { "type": "number" },
          "sn:unit": { "type": "string" },
          "sn:evidenceLevel": { "type": "string", "enum": ["A", "B", "C", "D"] }
        }
      }
    },
    "sn:affects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["@id"],
        "properties": {
          "@id": { "type": "string" },
          "sn:effectType": { "type": "string", "enum": ["protective", "therapeutic", "adverse"] },
          "sn:evidenceLevel": { "type": "string", "enum": ["A", "B", "C", "D"] }
        }
      }
    },
    "sn:contraindications": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sn:evidenceLevel": { "type": "string", "enum": ["A", "B", "C", "D"] },
    "owl:sameAs": { "type": ["string", "array"] },
    "skos:exactMatch": { "type": ["string", "array"] },
    "skos:closeMatch": { "type": ["string", "array"] }
  },
  "additionalProperties": true
}
